#!/usr/bin/env python3

import socketio
import socket
import threading
import time

# ======================== CONFIG ========================
NODE_URL = "http://localhost:3000"

TEENSY_IP = "192.168.2.177"
TEENSY_PORT = 5000

NUM_THRUSTERS = 6
NUM_MD = 8
TOTAL = NUM_THRUSTERS + NUM_MD

packet = [1500] * TOTAL
lock = threading.Lock()

# ======================== TEENSY CONNECTION ========================
class TeensyConn:
    def __init__(self):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.connect((TEENSY_IP, TEENSY_PORT))
        self.sock.settimeout(0.1)

    def send(self, msg):
        try:
            self.sock.sendall(msg.encode())
        except:
            print("Teensy connection lost")

conn = TeensyConn()

# ======================== STREAM TO TEENSY ========================
def stream():
    global packet

    while True:
        with lock:
            # ALWAYS enforce motor drivers = 1500
            for i in range(NUM_THRUSTERS, TOTAL):
                packet[i] = 1500

            msg = ",".join(str(x) for x in packet) + "\n"

        conn.send(msg)
        time.sleep(0.05)

# ======================== SOCKET.IO ========================
sio = socketio.Client()

@sio.event
def connect():
    print("Connected to Node.js")

@sio.on("thruster-pwm")
def on_thruster_pwm(pwms):
    global packet

    if isinstance(pwms, list) and len(pwms) == NUM_THRUSTERS:
        print("Thrusters received:", pwms)

        with lock:
            # update ONLY thrusters
            for i in range(NUM_THRUSTERS):
                packet[i] = pwms[i]

            # motor drivers forced to 1500
            for i in range(NUM_THRUSTERS, TOTAL):
                packet[i] = 1500

    else:
        print("Bad data:", pwms)

# ======================== MAIN ========================
def main():
    print("Connecting to Node server...")
    sio.connect(NODE_URL)

    print("Bridge running: Node → Python → Teensy")

    threading.Thread(target=stream, daemon=True).start()

    while sio.connected:
        time.sleep(0.1)

if __name__ == "__main__":
    main()
