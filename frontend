<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Jalpari Mission Control v8</title>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    html, body { margin: 0; padding: 0; height: 100%; background: #0f172a; color: #f8fafc; font-family: 'Segoe UI', sans-serif; }
    body { overflow: hidden; }
    * { box-sizing: border-box; }
    .main-layout { display: grid; grid-template-columns: 320px 1fr 340px; gap: 12px; height: 100vh; padding: 10px; min-width: 0; }
    .card { background: #1e293b; padding: 10px; border-radius: 8px; border: 1px solid #334155; }
    .column { display: flex; flex-direction: column; gap: 10px; height: 100%; min-height: 0; }
    .left-column { overflow-y: auto; padding-right: 4px; min-height: 0; }
    .right-column { overflow-y: auto; padding-left: 4px; min-height: 0; }
    
    /* DUAL RC GIMBALS */
    .dual-gimbals { display: flex; justify-content: space-between; gap: 10px; padding: 10px 0; }
    .gimbal-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px; }
    .gimbal-label { font-size: 10px; color: #94a3b8; text-transform: uppercase; font-weight: bold; }
    .trackpad { width: 100%; aspect-ratio: 1 / 1; border-radius: 50%; border: 2px solid #334155; background: radial-gradient(circle at center, #1e293b, #0f172a); position: relative; overflow: hidden; box-shadow: inset 0 0 15px rgba(0,0,0,0.5); }
    .trackpad::before, .trackpad::after { content: ""; position: absolute; background: #334155; }
    .trackpad::before { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }
    .trackpad::after { top: 50%; left: 0; width: 100%; height: 2px; transform: translateY(-50%); }
    .joystick-dot { position: absolute; left: 50%; top: 50%; width: 18px; height: 18px; border-radius: 50%; background: #38bdf8; box-shadow: 0 0 10px #38bdf8; transform: translate(-50%, -50%); pointer-events: none; transition: transform 0.05s linear; z-index: 2; }
    .joystick-dot.right-stick { background: #facc15; box-shadow: 0 0 10px #facc15; }

    /* TRUE 3D MINI ROV VISUALIZER */
    .heave-yaw-display { width: 100%; aspect-ratio: 1 / 1; border-radius: 12px; border: 2px solid #334155; background: #0b1221; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; perspective: 600px; }
    .heave-yaw-display::before { content: ""; position: absolute; width: 100%; height: 2px; background: #1e293b; top: 50%; left: 0; transform: translateY(-50%); }
    .heave-yaw-display::after { content: "SURFACE"; position: absolute; top: 4px; font-size: 8px; color: #475569; letter-spacing: 2px; }
    
    /* Preserve-3D ensures the child elements pop out in Z space */
    .tiny-rov { position: relative; width: 40px; height: 60px; transition: transform 0.05s linear; z-index: 5; transform-style: preserve-3d; }
    .tiny-rov-body { position: absolute; top: 10%; left: 10%; width: 80%; height: 80%; background: linear-gradient(to bottom, #facc15, #ca8a04); border-radius: 6px; z-index: 2; box-shadow: 0 5px 15px rgba(0,0,0,0.6); transform-style: preserve-3d; }
    
    /* Z-Translation pops the nose and dome out towards the screen */
    .tiny-rov-nose { position: absolute; top: -5px; left: 50%; transform: translateX(-50%) translateZ(10px); width: 16px; height: 8px; background: #f97316; border-radius: 4px 4px 0 0; z-index: 3; box-shadow: 0 0 8px #f97316; }
    .tiny-rov-dome { position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%) translateZ(15px); width: 14px; height: 14px; background: #38bdf8; border-radius: 50%; z-index: 4; border: 2px solid #0f172a; box-shadow: inset -2px -2px 4px rgba(0,0,0,0.5); }
    
    .tiny-rov-prop { position: absolute; width: 10px; height: 16px; background: #334155; border-radius: 4px; z-index: 1; border: 1px solid #475569; }
    .tiny-rov-prop.tl { top: 0px; left: -6px; }
    .tiny-rov-prop.tr { top: 0px; right: -6px; }
    .tiny-rov-prop.bl { bottom: 0px; left: -6px; }
    .tiny-rov-prop.br { bottom: 0px; right: -6px; }

    /* ROV THRUSTER SCHEMATIC */
    .rov-map-container { display: flex; justify-content: center; padding: 15px 0; }
    .rov-hull { width: 120px; height: 180px; border: 2px solid #475569; border-radius: 20px; position: relative; background: rgba(15, 23, 42, 0.5); }
    .rov-nose { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); width: 40px; height: 10px; background: #f97316; border-radius: 5px 5px 0 0; z-index: 3; box-shadow: 0 0 10px #f97316; }
    .thruster-node { position: absolute; width: 24px; height: 36px; background: #334155; border-radius: 6px; border: 2px solid #1e293b; transition: background-color 0.1s linear, box-shadow 0.1s linear; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: bold; color: rgba(255,255,255,0.4); }
    
    /* VECTORED CONFIGURATION: Front \ / and Rear / \ */
    .node-fl { top: -10px; left: -15px; transform: rotate(-45deg); }
    .node-fr { top: -10px; right: -15px; transform: rotate(45deg); }
    .node-rl { bottom: -10px; left: -15px; transform: rotate(45deg); }
    .node-rr { bottom: -10px; right: -15px; transform: rotate(-45deg); }
    
    /* Vertical Sides */
    .node-vl { top: 50%; left: -18px; transform: translateY(-50%); border-radius: 50%; width: 30px; height: 30px; }
    .node-vr { top: 50%; right: -18px; transform: translateY(-50%); border-radius: 50%; width: 30px; height: 30px; }

    .box-grid { display: grid; gap: 10px; }
    .box-grid-2x2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .box-grid-3x2 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .value-box { background: #08111f; border: 1px solid #23314c; border-radius: 10px; padding: 10px; min-height: 60px; text-align: center; }
    .value-box .value { font-size: 18px; font-weight: 700; color: #38bdf8; font-family: Consolas, monospace; margin-top: 4px;}
    .camera-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: repeat(2, minmax(120px, 1fr)); gap: 8px; height: 100%; min-height: 0; }
    .video-box { background: #000; border: 2px solid #475569; border-radius: 4px; display: flex; align-items: center; justify-content: center; position: relative; color: #475569; font-weight: bold; font-size: 12px; min-height: 120px; }
    .cam-tag { position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.7); font-size: 10px; padding: 3px 8px; color: #38bdf8; border-radius: 2px; }
    .camera-column { display: flex; flex-direction: column; min-height: 0; }
    .compass { width: 100px; height: 100px; border: 3px solid #38bdf8; border-radius: 50%; position: relative; margin: 8px auto; background: #000; overflow: hidden; }
    .yaw-needle { width: 4px; height: 38px; background: #ef4444; position: absolute; left: 50%; bottom: 50%; transform-origin: bottom center; transition: transform 0.05s linear; }
    .horizon-wrap { width: 100%; height: 100%; position: absolute; top: 0; left: 0; overflow: hidden; border-radius: 50%; }
    .horizon-line { width: 90%; height: 2px; background: #22c55e; position: absolute; top: 50%; left: 50%; transform-origin: center center; transition: transform 0.05s linear; }
    h3 { font-size: 11px; margin: 0 0 8px 0; color: #38bdf8; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #334155; padding-bottom: 4px; }
    .label { font-size: 10px; color: #94a3b8; text-transform: uppercase; }
    .val-num { font-family: monospace; font-size: 18px; color: #38bdf8; font-weight: bold; }
    #conn { font-weight: bold; margin-left: 6px; }
    .dir-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; margin-top: 5px; }
.dir-btn { padding: 4px; font-size: 10px; cursor: pointer; border: 1px solid #334155; border-radius: 3px; background: #334155; color: white; }
  </style>
</head>
<body>
  <div class="main-layout">
    <div class="column left-column">
      
      <div class="card">
        <h3>SYSTEM MODIFIERS</h3>
        <div class="box-grid box-grid-2x2">
          <div class="value-box" style="border-color:#38bdf8;">
            <div class="label">Master Gain</div>
            <div class="value" id="valGain">50%</div>
          </div>
          <div class="value-box" id="stabBox" style="border-color:#ef4444;">
            <div class="label">Stability Mode</div>
            <div class="value" id="valStab" style="color:#ef4444;">MANUAL</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3>6-DOF TELEMETRY (RAW)</h3>
        <div class="box-grid box-grid-3x2">
          <div class="value-box"><div class="label">Surge (Y)</div><div class="value" id="valSurge">0%</div></div>
          <div class="value-box"><div class="label">Sway (X)</div><div class="value" id="valSway">0%</div></div>
          <div class="value-box"><div class="label">Heave (Z)</div><div class="value" id="valHeave">0%</div></div>
          <div class="value-box"><div class="label">Yaw</div><div class="value" id="valYaw">0%</div></div>
          <div class="value-box"><div class="label">Pitch</div><div class="value" id="valPitch">0%</div></div>
          <div class="value-box"><div class="label">Roll</div><div class="value" id="valRoll">0%</div></div>
        </div>
      </div>

      <div class="card">
        <h3>FLIGHT CONTROLS</h3>
        <div class="dual-gimbals">
          <div class="gimbal-wrap">
            <div class="gimbal-label">Sway / Surge</div>
            <div class="trackpad" id="trackpad">
              <div class="joystick-dot" id="leftStick"></div>
            </div>
          </div>
          <div class="gimbal-wrap">
            <div class="gimbal-label">Yaw (Rotate) / Heave (Up)</div>
            <div class="heave-yaw-display">
              <div class="tiny-rov" id="rightStickROV">
                <div class="tiny-rov-body">
                   <div class="tiny-rov-dome"></div>
                </div>
                <div class="tiny-rov-nose"></div>
                <div class="tiny-rov-prop tl"></div>
                <div class="tiny-rov-prop tr"></div>
                <div class="tiny-rov-prop bl"></div>
                <div class="tiny-rov-prop br"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="camera-column">
      <div class="camera-grid">
        <div class="video-box"><span class="cam-tag">CAM 1</span>NO SIGNAL</div>
        <div class="video-box"><span class="cam-tag">CAM 2</span>NO SIGNAL</div>
        <div class="video-box"><span class="cam-tag">CAM 3</span>NO SIGNAL</div>
        <div class="video-box"><span class="cam-tag">CAM 4</span>NO SIGNAL</div>
      </div>
    </div>

    <div class="column right-column">
      <div class="card" style="text-align:center;">
        <h3>ORIENTATION</h3>
        <div class="label">STATUS <span id="conn">DISCONNECTED</span></div>
        <div class="compass"><div class="yaw-needle" id="yaw-needle"></div></div>
        <div class="label" style="margin-top:10px;">PITCH & ROLL</div>
        <div class="compass" style="border-color:#22c55e;">
          <div class="horizon-wrap"><div class="horizon-line" id="pr-line"></div></div>
        </div>
        <div style="font-size:11px; margin-top:5px;">P: <span id="pv">0</span>° | R: <span id="rv">0</span>°</div>
      </div>

      <div class="card">
        <div class="card">
  <h3>THRUSTER CALIBRATION</h3>
  <div class="dir-grid" id="dir-grid"></div>
</div>
        <h3>LIVE THRUSTER MAP</h3>
        <div class="rov-map-container">
          <div class="rov-hull">
            <div class="rov-nose"></div>
            <div class="thruster-node node-fl" id="visFL">FL</div>
            <div class="thruster-node node-fr" id="visFR">FR</div>
            <div class="thruster-node node-rl" id="visRL">RL</div>
            <div class="thruster-node node-rr" id="visRR">RR</div>
            <div class="thruster-node node-vl" id="visVL">VL</div>
            <div class="thruster-node node-vr" id="visVR">VR</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3>SENSORS</h3>
        <div class="label">Depth</div>
        <div class="val-num" id="depth">0.00 m</div>
        <div class="label" style="margin-top:10px;">Network</div>
        <div style="color:#22c55e; font-weight:bold;"><span id="ping">0</span> ms</div>
      </div>
    </div>
  </div>

  <script>
    const socket = io();
        // Thruster Calibration Buttons
    const dirGrid = document.getElementById('dir-grid');
    [1, 2, 3, 4, 5, 6].forEach(id => {
      dirGrid.innerHTML += `<button onclick="socket.emit('toggle-direction', ${id})" class="dir-btn" id="dbtn-${id}">T${id}: N</button>`;
    });

    socket.on('direction-update', (data) => {
      const btn = document.getElementById(`dbtn-${data.id}`);
      btn.innerText = `T${data.id}: ${data.dir === 1 ? 'N' : 'R'}`;
      btn.style.background = data.dir === 1 ? '#334155' : '#ef4444';
    });
    let yawAccum = 0; let lastYaw = null; let gpIndex = null;

    socket.on('connect', () => {
      const connEl = document.getElementById('conn');
      connEl.innerText = 'CONNECTED';
      connEl.style.color = '#22c55e';
    });
    
    socket.on('disconnect', () => {
      const connEl = document.getElementById('conn');
      connEl.innerText = 'DISCONNECTED';
      connEl.style.color = '#f87171';
    });

    socket.on('robot-data', (data) => {
      const yaw = Number(data.yaw) || 0;
      const pitch = Number(data.pitch) || 0;
      const roll = Number(data.roll) || 0;

      if (lastYaw === null) yawAccum = yaw;
      else {
        let delta = yaw - lastYaw;
        if (delta > 180) delta -= 360;
        if (delta < -180) delta += 360;
        yawAccum += delta;
      }
      lastYaw = yaw;
      const pitchMove = Math.max(-18, Math.min(18, pitch * -2));

      document.getElementById('yaw-needle').style.transform = `translateX(-50%) rotate(${yawAccum - 90}deg)`;
      document.getElementById('pr-line').style.transform = `translate(-50%, ${pitchMove}px) rotate(${-roll}deg)`;
      document.getElementById('pv').innerText = pitch.toFixed(1);
      document.getElementById('rv').innerText = roll.toFixed(1);
      document.getElementById('depth').innerText = ((data.depth ?? 0).toFixed ? (data.depth ?? 0).toFixed(2) : '0.00') + ' m';
      document.getElementById('ping').innerText = Math.round(data.ping ?? 0);
    });

    // UI Elements
    const leftStick = document.getElementById('leftStick');
    const rightStickRov = document.getElementById('rightStickROV');
    
    // Thruster Visual Nodes
    const visNodes = {
      FL: document.getElementById('visFL'), FR: document.getElementById('visFR'),
      RL: document.getElementById('visRL'), RR: document.getElementById('visRR'),
      VL: document.getElementById('visVL'), VR: document.getElementById('visVR')
    };

    // --- STATE VARIABLES ---
    let nx = 0, ny = 0, yawNorm = 0, verticalNorm = 0;
    let masterGain = 0.50, stabilityMode = false, currentPitch = 0, currentRoll = 0;
    let thumbWasPressed = false, hatUpWasPressed = false, hatDownWasPressed = false;

    // --- CALIBRATION VARIABLES ---
    let offsetX = 0, offsetY = 0, offsetYaw = 0, offsetThrottle = 0;
    let btn8WasPressed = false;

    const clamp = (v, min, max) => Math.max(min, Math.min(max, v));
    const mixToPwm = (v) => Math.round(clamp(1500 + v * 400, 1100, 1900));

    // Colors Thrusters Based on PWM
    function styleThrusterNode(element, pwm) {
      if (pwm > 1530) {
        const intensity = (pwm - 1500) / 400;
        element.style.backgroundColor = `rgba(34, 197, 94, ${0.4 + (intensity * 0.6)})`;
        element.style.boxShadow = `0 0 15px rgba(34, 197, 94, ${intensity})`;
      } else if (pwm < 1470) {
        const intensity = (1500 - pwm) / 400;
        element.style.backgroundColor = `rgba(239, 68, 68, ${0.4 + (intensity * 0.6)})`;
        element.style.boxShadow = `0 0 15px rgba(239, 68, 68, ${intensity})`;
      } else {
        element.style.backgroundColor = '#334155';
        element.style.boxShadow = 'none';
      }
    }

    function updateUIElements() {
      leftStick.style.transform = `translate(calc(-50% + ${nx * 40}px), calc(-50% + ${ny * 40}px))`;
      
      // The 3D CSS mapping makes the nose physically pop out and rotate intuitively
      if (rightStickRov) {
        rightStickRov.style.transform = `translateY(${-verticalNorm * 40}px) rotateZ(${yawNorm * 45}deg) rotateX(${currentPitch * 60}deg)`;
      }

      document.getElementById('valGain').textContent = Math.round(masterGain * 100) + '%';
      const stabEl = document.getElementById('valStab');
      const stabBox = document.getElementById('stabBox');
      
      if (stabilityMode) {
          stabEl.textContent = 'LOCKED'; stabEl.style.color = '#22c55e'; stabBox.style.borderColor = '#22c55e';
      } else {
          stabEl.textContent = 'MANUAL'; stabEl.style.color = '#ef4444'; stabBox.style.borderColor = '#ef4444';
      }

      document.getElementById('valSurge').textContent = Math.round(-ny * 100) + '%'; 
      document.getElementById('valSway').textContent = Math.round(nx * 100) + '%';
      document.getElementById('valHeave').textContent = Math.round(verticalNorm * 100) + '%';
      document.getElementById('valYaw').textContent = Math.round(yawNorm * 100) + '%';
      document.getElementById('valPitch').textContent = Math.round(currentPitch * 100) + '%';
      document.getElementById('valRoll').textContent = Math.round(currentRoll * 100) + '%';
    }

    function updateThrusters() {
      const forward = -ny, strafe = nx, yaw = yawNorm, vertical = verticalNorm, roll = currentRoll;

      // MATHEMATICAL FIX: Corrected Vectored Mixing for standard BlueRobotics Layout
      // Front thrusters point IN (\ /) and Rear thrusters point IN (/ \)
      let fl = forward + strafe + yaw;
      let fr = forward - strafe - yaw;
      let rl = forward + strafe - yaw; 
      let rr = forward - strafe + yaw; 

      const max_h = Math.max(1.0, Math.abs(fl), Math.abs(fr), Math.abs(rl), Math.abs(rr));
      fl /= max_h; fr /= max_h; rl /= max_h; rr /= max_h;

      let vl = vertical + roll;
      let vr = vertical - roll;
      const max_v = Math.max(1.0, Math.abs(vl), Math.abs(vr));
      vl /= max_v; vr /= max_v;

      const values = {
        FL: mixToPwm(fl), FR: mixToPwm(fr), RL: mixToPwm(rl), RR: mixToPwm(rr),
        VL: mixToPwm(vl), VR: mixToPwm(vr)  
      };

      for (const k of Object.keys(values)) {
        styleThrusterNode(visNodes[k], values[k]);
      }

      updateUIElements();
    }

    function emitJoystick() {
      socket.emit('joystick-input', { 
        x: nx, y: ny, yaw: yawNorm, vertical: verticalNorm,
        pitch: currentPitch, roll: currentRoll, gain: masterGain, stability: stabilityMode
        
      });
    }

    function setFromPointer(clientX, clientY) {
      const trackpad = document.getElementById('trackpad');
      const rect = trackpad.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = clientX - cx;
      const dy = clientY - cy;
      const maxDist = Math.min(rect.width, rect.height) / 2 - 16;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const scale = dist > maxDist ? maxDist / dist : 1;

      nx = clamp((dx * scale) / maxDist, -1, 1);
      ny = clamp((dy * scale) / maxDist, -1, 1);

      updateThrusters();
      emitJoystick();
    }

    let dragging = false;
    document.getElementById('trackpad').addEventListener('pointerdown', (e) => {
      dragging = true; e.target.setPointerCapture(e.pointerId); setFromPointer(e.clientX, e.clientY);
    });

    document.getElementById('trackpad').addEventListener('pointermove', (e) => {
      if (!dragging) return; setFromPointer(e.clientX, e.clientY);
    });

    function resetPad() {
      dragging = false; nx = 0; ny = 0;
      updateThrusters(); emitJoystick();
    }

    document.getElementById('trackpad').addEventListener('pointerup', resetPad);
    document.getElementById('trackpad').addEventListener('pointercancel', resetPad);
    window.addEventListener('resize', updateThrusters);

    function pollGamepad() {
      const pads = navigator.getGamepads ? navigator.getGamepads() : [];
      const gp = gpIndex !== null ? pads[gpIndex] : pads[0];

      if (gp) {
        
        // --- 1. HARDWARE CALIBRATION (BUTTON 8) ---
        const calibBtn = gp.buttons[8]?.pressed;
        if (calibBtn && !btn8WasPressed) {
          offsetX = gp.axes[0] || 0;
          offsetY = gp.axes[1] || 0;
          offsetYaw = gp.axes[5] ?? gp.axes[2] ?? 0;
          offsetThrottle = gp.axes[6] ?? gp.axes[3] ?? 0;
          
          const connEl = document.getElementById('conn');
          if (connEl) {
            connEl.innerText = 'CALIBRATED ZERO';
            connEl.style.color = '#facc15'; 
            setTimeout(() => { connEl.innerText = 'CONNECTED'; connEl.style.color = '#22c55e'; }, 1000);
          }
        }
        btn8WasPressed = calibBtn;

        // --- 2. APPLY OFFSETS, SYMMETRICAL SCALING & DEADZONE ---
        function scaleAxis(raw, offset) {
          if (raw === offset) return 0;
          const shortestDist = Math.min(1.0 - offset, offset + 1.0);
          let scaled = (raw - offset) / shortestDist;
          return Math.max(-1.0, Math.min(1.0, scaled));
        }

        const deadzone = (v) => Math.abs(v) < 0.05 ? 0 : v;

        const raw_x = deadzone(scaleAxis(gp.axes[0] || 0, offsetX));
        const raw_y = deadzone(scaleAxis(gp.axes[1] || 0, offsetY));
        const raw_yaw = deadzone(scaleAxis(gp.axes[5] ?? gp.axes[2] ?? 0, offsetYaw));
        const raw_throttle = deadzone(scaleAxis(gp.axes[6] ?? gp.axes[3] ?? 0, offsetThrottle));

        // --- 3. STANDARD BUTTON LOGIC ---
        const trigger = gp.buttons[0]?.pressed;
        const thumb = gp.buttons[1]?.pressed;

        const axis9 = gp.axes[9];
        const isHatUpAxis = (axis9 !== undefined && axis9 >= -1.0 && axis9 <= -0.5);
        const isHatDownAxis = (axis9 !== undefined && axis9 > 0.1 && axis9 <= 1.0); 

        const hatUp = gp.buttons[12]?.pressed || gp.buttons[2]?.pressed || isHatUpAxis;
        const hatDown = gp.buttons[13]?.pressed || gp.buttons[3]?.pressed || isHatDownAxis;

        if (hatUp && !hatUpWasPressed) masterGain = Math.min(1.0, masterGain + 0.1);
        if (hatDown && !hatDownWasPressed) masterGain = Math.max(0.1, masterGain - 0.1);
        hatUpWasPressed = hatUp; hatDownWasPressed = hatDown;

        if (thumb && !thumbWasPressed) stabilityMode = !stabilityMode;
        thumbWasPressed = thumb;

        if (Math.abs(raw_x) > 0.3 || Math.abs(raw_y) > 0.3 || Math.abs(raw_yaw) > 0.3 || Math.abs(raw_throttle) > 0.3) stabilityMode = false;

        // --- 4. FLIGHT STRATEGY & MIXING ---
        let surge = 0, sway = 0, pitch = 0, roll = 0, yaw = 0;
        
        if (trigger) {
          pitch = raw_y * masterGain; 
          roll = raw_x * masterGain;
          yaw = raw_yaw * masterGain; 
        } else {
          surge = raw_y * masterGain; 
          sway = raw_x * masterGain;
          yaw = 0; 
        }

        let heave = -raw_throttle * masterGain; 

        nx = clamp(sway, -1, 1); ny = clamp(surge, -1, 1); 
        yawNorm = clamp(yaw, -1, 1); verticalNorm = clamp(heave, -1, 1);
        currentPitch = clamp(pitch, -1, 1); currentRoll = clamp(roll, -1, 1);

        updateThrusters();
        emitJoystick();
      }
      requestAnimationFrame(pollGamepad);
    }

    window.addEventListener('gamepadconnected', (e) => {
      gpIndex = e.gamepad.index;
      requestAnimationFrame(pollGamepad);
    });

    updateThrusters();
  </script>
</body>
</html>
