          <yDotV>-1</yDotV>
          <zDotW>-2</zDotW>

          <xUU>-10</xUU>
          <yVV>-10</yVV>
          <zWW>-15</zWW>

          <linear_damping>5</linear_damping>
          <angular_damping>5</angular_damping>
