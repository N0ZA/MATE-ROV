      <link name="wall_north">
        <collision name="collision">
          <geometry>
            <box><size>20 0.5 5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>20 0.5 5</size></box>
          </geometry>
        </visual>
        <pose>0 10 -2.5 0 0 0</pose>
      </link>

     
      <link name="wall_south">
        <collision name="collision">
          <geometry>
