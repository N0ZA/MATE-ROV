    <model name="test_cube">
      <pose>0 0 -1 0 0 0</pose>
      <static>false</static>

      <link name="cube_link">

        
        <inertial>
          <mass>2</mass>
          <inertia>
            <ixx>0.01</ixx>
            <iyy>0.01</iyy>
            <izz>0.01</izz>
